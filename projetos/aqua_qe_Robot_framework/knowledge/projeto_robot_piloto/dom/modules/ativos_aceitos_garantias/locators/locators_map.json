      "strategy": "aria-label"
    },
    {
      "name": "export_button",
      "selector": "css:button[aria-label='Exportar Arquivo']",
      "strategy": "aria-label"
    },
    {
      "name": "export_menu",
      "selector": "css:ul[role='menu'][aria-label='Opções de exportação']",
      "strategy": "role+aria-label"
    },
    {
      "name": "export_current_csv",
      "selector": "css:button[aria-label='Exportar arquivo CSV consulta atual']",
      "strategy": "aria-label"
    },
    {
      "name": "export_full_csv",
      "selector": "css:button[aria-label='Exportar arquivo CSV base completa']",
      "strategy": "aria-label"
    },
    {
      "name": "data_table",
      "selector": "css:table[aria-label='Tabela de ativos aceitos em garantia']",
