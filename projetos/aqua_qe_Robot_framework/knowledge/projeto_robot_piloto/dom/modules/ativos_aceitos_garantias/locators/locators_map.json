{
  "module": "ativos_aceitos_garantias",
  "source": "manual-chat-import-2026-07-01",
  "notes": [
    "Mapa inicial derivado do snapshot DOM enviado no chat.",
    "Priorizar aria-label, role, id e data-testid quando disponiveis.",
    "Nao reutilizar estes locators para limites_posicoes sem um snapshot real da tela correta."
  ],
  "locators": [
    {
