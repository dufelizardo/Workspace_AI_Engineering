      "selector": "css:main#conteudo",
      "strategy": "id"
    },
    {
      "name": "breadcrumb_nav",
      "selector": "css:nav[aria-label='Caminho de navegação']",
      "strategy": "aria-label"
    },
    {
      "name": "page_title",
      "selector": "css:h1.b3-section__title",
      "strategy": "semantic-heading"
    },
    {
      "name": "back_button",
      "selector": "css:button[aria-label='Voltar para a página anterior']",
      "strategy": "aria-label"
    },
    {
      "name": "search_form",
      "selector": "css:form[role='search'][aria-label='Busca e filtros de ativos']",
      "strategy": "role+aria-label"
    },
    {
      "name": "search_input",
      "selector": "css:input[aria-label='Campo de busca por Ticker ou ISIN']",
      "strategy": "aria-label"
    },
    {
      "name": "category_filter_group",
